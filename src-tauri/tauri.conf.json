{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDronelog Sync",
  "version": "0.1.0",
  "identifier": "com.opendronelog.sync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenDronelog Sync",
        "width": 1120,
        "height": 760,
        "minWidth": 360,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "versionCode": 1000004
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
